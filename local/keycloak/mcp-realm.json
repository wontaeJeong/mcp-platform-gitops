{
  "realm": "mcp",
  "enabled": true,
  "displayName": "MCP Local Development",
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": false,
  "clients": [
    {
      "clientId": "mcp-local",
      "name": "MCP local PKCE client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": false,
      "redirectUris": [
        "http://127.0.0.1:8765/callback"
      ],
      "webOrigins": [],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "basic",
        "mcp-mock-audience"
      ],
      "optionalClientScopes": [
        "mcp:mock:use"
      ],
      "protocolMappers": [
        {
          "name": "loginid",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "loginid",
            "claim.name": "loginid",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "mcp-inspector",
      "name": "MCP Inspector 0.22.0",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": false,
      "redirectUris": [
        "http://localhost:6274/oauth/callback",
        "http://localhost:6274/oauth/callback/debug"
      ],
      "webOrigins": [
        "http://localhost:6274"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "basic",
        "mcp-mock-audience"
      ],
      "optionalClientScopes": [
        "mcp:mock:use"
      ],
      "protocolMappers": [
        {
          "name": "loginid",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "loginid",
            "claim.name": "loginid",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "mcp-api-tests",
      "name": "MCP lower-level API tests",
      "enabled": true,
      "protocol": "openid-connect",
      "clientAuthenticatorType": "client-secret",
      "secret": "${MCP_API_TESTS_CLIENT_SECRET}",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "fullScopeAllowed": false,
      "defaultClientScopes": [
        "basic",
        "mcp-mock-audience"
      ],
      "optionalClientScopes": [
        "mcp:mock:use"
      ],
      "protocolMappers": [
        {
          "name": "loginid",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "loginid",
            "claim.value": "mcp-api-tests",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "basic",
      "description": "Subject claim required by MCP gateway identity validation",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "Subject (sub)",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "id.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "mcp-mock-audience",
      "description": "Compatibility audience for Keycloak 26 local tokens",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "mock-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "http://gateway.localhost:8080/mock/mcp",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "mcp:mock:use",
      "description": "Permission to use the local mock MCP server",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "mock-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "http://gateway.localhost:8080/mock/mcp",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "local-user",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Local",
      "lastName": "Developer",
      "email": "local-user@example.test",
      "attributes": {
        "loginid": [
          "local-user"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "${LOCAL_USER_PASSWORD}",
          "temporary": false
        }
      ]
    }
  ]
}
